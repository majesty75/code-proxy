{
  "id": null,
  "uid": "uta-fleet-grid-v1",
  "title": "UTA Fleet — Rack & Slot Grid",
  "description": "Physical rack/shelf/slot view of every test board. Click any slot to drill into the Board Detail dashboard.",
  "tags": ["uta", "fleet", "rack"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },

  "templating": {
    "list": [
      {
        "type": "query",
        "name": "rack",
        "label": "Rack",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "query": "SELECT DISTINCT toString(rack) FROM uta.test_sessions FINAL WHERE rack > 0 ORDER BY rack",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      },
      {
        "type": "query",
        "name": "platform",
        "label": "Platform",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "query": "SELECT DISTINCT platform FROM uta.test_sessions FINAL WHERE platform != '' ORDER BY platform",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      },
      {
        "type": "query",
        "name": "fw_version",
        "label": "Firmware",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "query": "SELECT DISTINCT firmware_version FROM uta.test_sessions FINAL WHERE firmware_version != '' ORDER BY firmware_version",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT count() FROM uta.test_sessions FINAL WHERE status = 'RUNNING'",
        "format": "table"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Boards Failed (window)",
      "description": "Number of distinct boards that emitted any FAILED pass/fail marker or test-step end in the dashboard time range.",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT countDistinct(slot_id) FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime AND JSONExtractString(parsed, 'status') = 'FAILED'",
        "format": "table"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pass Markers",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "green", "mode": "fixed" }, "unit": "short" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT count() FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime AND JSONExtractString(parsed, 'status') = 'PASSED'",
        "format": "table"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Fail Markers",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "unit": "short" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT count() FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime AND JSONExtractString(parsed, 'status') = 'FAILED'",
        "format": "table"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Lines (window)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" }, "unit": "short" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT count() FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime",
        "format": "table"
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Slots In Use",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT countDistinct(slot_id) FROM uta.test_sessions FINAL WHERE status IN ('RUNNING','PASSED','FAILED','COMPLETED','UNKNOWN')",
        "format": "table"
      }]
    },

    {
      "id": 10,
      "type": "table",
      "title": "Rack & Board Grid — click any slot to drill in",
      "description": "Latest status per board, grouped by Rack/Shelf/Slot. Cell colour = current status. Click slot_id to open Board Detail.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 12 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "showHeader": true, "footer": { "show": false }, "sortBy": [{ "displayName": "rack", "desc": false }] },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto" },
          "links": [{
            "title": "Open Board Detail",
            "url": "/d/uta-board-detail-v1/uta-board-detail?var-slot_id=${__data.fields.slot_id}&var-log_filename=All&${__url_time_range}",
            "targetBlank": false
          }]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "RUNNING":   { "color": "blue",  "text": "🔵 RUNNING"   } } },
                { "type": "value", "options": { "PASSED":    { "color": "green", "text": "✅ PASSED"    } } },
                { "type": "value", "options": { "FAILED":    { "color": "red",   "text": "❌ FAILED"    } } },
                { "type": "value", "options": { "COMPLETED": { "color": "green", "text": "🏁 COMPLETED" } } },
                { "type": "value", "options": { "UNKNOWN":   { "color": "gray",  "text": "❓ UNKNOWN"   } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "fail_count" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "slot_id" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT ts.rack AS rack, ts.shelf AS shelf, ts.slot AS slot, ts.slot_id AS slot_id, ts.platform AS platform, ts.firmware_version AS firmware, ts.project AS project, ts.test_purpose AS test_purpose, ts.status AS status, ts.started_at AS started_at, dateDiff('minute', ts.started_at, now()) AS minutes_running, le.fail_count AS fail_count, le.line_count AS line_count FROM uta.test_sessions AS ts FINAL LEFT JOIN ( SELECT slot_id, countIf(JSONExtractString(parsed, 'status') = 'FAILED') AS fail_count, count() AS line_count FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime GROUP BY slot_id ) AS le ON ts.slot_id = le.slot_id WHERE match(toString(ts.rack), '${rack:regex}') AND match(ts.platform, '${platform:regex}') AND match(ts.firmware_version, '${fw_version:regex}') ORDER BY ts.rack, ts.shelf, ts.slot",
        "format": "table"
      }]
    },

    {
      "id": 20,
      "type": "state-timeline",
      "title": "Slot Status Timeline (click a band → drill in)",
      "description": "Each row = one slot. Coloured bands show RUNNING/PASSED/FAILED/COMPLETED status changes over time.",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "rowHeight": 0.85,
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "RUNNING":   { "color": "blue"  } } },
            { "type": "value", "options": { "PASSED":    { "color": "green" } } },
            { "type": "value", "options": { "FAILED":    { "color": "red"   } } },
            { "type": "value", "options": { "COMPLETED": { "color": "dark-green" } } },
            { "type": "value", "options": { "UNKNOWN":   { "color": "gray"  } } }
          ],
          "color": { "mode": "thresholds" },
          "links": [{
            "title": "Open Board Detail",
            "url": "/d/uta-board-detail-v1/uta-board-detail?var-slot_id=${__field.name}&var-log_filename=All&${__url_time_range}",
            "targetBlank": false
          }]
        }
      },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "WITH events AS ( SELECT coalesce(log_timestamp, ingested_at) AS time, slot_id, multiIf( JSONExtractString(parsed,'event')='test_step' AND JSONExtractString(parsed,'kind')='end', JSONExtractString(parsed,'status'), JSONExtractString(parsed,'event')='pass_fail', JSONExtractString(parsed,'status'), '' ) AS status FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime ) SELECT time, slot_id AS metric, status AS value FROM events WHERE status != '' AND match(slot_id, '.+') ORDER BY time",
        "format": "time_series"
      }]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Lines per minute by Slot",
      "description": "Throughput per board",
      "gridPos": { "x": 0, "y": 26, "w": 16, "h": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum","mean"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 }, "unit": "short", "color": { "mode": "palette-classic" } } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT toStartOfMinute(ingested_at) AS time, slot_id AS metric, count() AS lines FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime GROUP BY time, slot_id ORDER BY time",
        "format": "time_series"
      }]
    },

    {
      "id": 31,
      "type": "piechart",
      "title": "Event Type Distribution (window)",
      "description": "Which parsers are claiming lines",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["value","percent"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-uta" },
        "rawSql": "SELECT JSONExtractString(parsed, 'event') AS event_type, count() AS cnt FROM uta.log_events WHERE ingested_at >= $__fromTime AND ingested_at <= $__toTime GROUP BY event_type ORDER BY cnt DESC LIMIT 15",
        "format": "table"
      }]
    }
  ]
}
