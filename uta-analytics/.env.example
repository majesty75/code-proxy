# ---- Network ----
# IP of the main server (the WSL host) as seen from external UTA servers
# For local-only POC inside WSL, leave as host.docker.internal
MAIN_SERVER_IP=host.docker.internal
# IP of the UTA server being monitored (only relevant for external Vector agents)
UTA_SERVER_IP=192.168.1.10

# ---- Kafka ----
KAFKA_BROKER_ID=1

# ---- ClickHouse ----
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000
UTA_CH_USERNAME=default
UTA_CH_PASSWORD=password

# ---- Grafana ----
GF_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=admin

# ---- Parser ----
UTA_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
UTA_KAFKA_TOPIC=raw-logs
# earliest = consume from start of topic on first run (recommended for POC)
# latest   = skip backlog, only consume new messages
UTA_KAFKA_OFFSET_RESET=earliest
UTA_CH_HOST=clickhouse
UTA_CH_PORT=8123
UTA_CH_DATABASE=uta
UTA_BATCH_SIZE=500
UTA_FLUSH_MAX_RETRIES=5
UTA_FLUSH_RETRY_MAX_SLEEP=30
